# AgriVision AI Backend — Environment Variables
# Copy this file to .env and fill in values

SECRET_KEY=your-super-secret-key-change-this
JWT_SECRET_KEY=your-jwt-secret-change-this

# Database (SQLite default, or use PostgreSQL in production)
DATABASE_URL=sqlite:///agrivision.db
# DATABASE_URL=postgresql://user:pass@localhost/agrivision

# Free API Keys (get them at the links below)
# News: https://newsapi.org (free 100 req/day)
NEWS_API_KEY=your_newsapi_key_here

# AI Chatbot: https://console.groq.com (free, fast Llama-3)
GROQ_API_KEY=your_groq_api_key_here

# Weather: Open-Meteo is FREE, no key needed! ✓
